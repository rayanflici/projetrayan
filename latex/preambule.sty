%--Left-bar--%
\renewenvironment{leftbar}{%
\def\FrameCommand{\color{CouleurExo}\hspace{1cm}\vrule width 1pt \hspace{0pt}}%
\MakeFramed{\advance\hsize -\width\FrameRestore}}
{\endMakeFramed}

\makeatletter

\newcounter{exo}
\newcounter{sol}
\newcommand{\@solutions}{} % Initialise la macro qui stocke tout

\newcommand{\exo}[2]{
    % Exercices
    \addtocounter{exo}{1}\par
    \medskip
	\textbf{\hypertarget{ex\theexo}{Exercice \theexo}}\quad\hyperlink{cor\theexo}{\textcolor{monrouge}{[Solution]}}\qquad #1\par
    % Solutions
    \g@addto@macro\@solutions{
        \addtocounter{sol}{1}\par
        \textbf{\hypertarget{cor\thesol}{\textcolor{monrouge}{Solution \thesol}}}\quad\hyperlink{ex\thesol}{[Énoncé]}\qquad #2\bigskip\par
    }
}

\newcommand{\printsol}{\@solutions}
\makeatother

%-- Définition --%
\NewTotalTColorBox[]{\definition}{ +m +m }
	{ 
    	notitle,
    	breakable, enhanced,
    	colback=definition!5!white,
    	frame hidden,
    	boxrule=0pt,
    	enhanced,
    	sharp corners,
    	borderline west={4pt}{0pt}{definition!50!black},
	}
	{\textcolor{definition!50!black}{\sffamily\textbf{Définition\def\temps{#1}\ifx\temps\empty{}\else~(#1)\fi.}} #2}

%-- Théorème --%
\NewTotalTColorBox[]{\thm}{ +m +m +m }
	{ 
    	notitle,
    	breakable, enhanced,
    	colback=theoreme!5!white,
    	colbacklower=white,
    	frame hidden,
    	boxrule=0pt,
    	bicolor,
    	sharp corners,
    	borderline west={4pt}{0pt}{theoreme!50!black},
    	fontupper=\sffamily
	}
	{
    	\textcolor{theoreme!50!black}{\sffamily\textbf{Théorème\def\temps{#1}\ifx\temps\empty{}\else~(#1)\fi.}}
        \\#2
    	\def\temp{#3}
    	\ifx\temp\empty{}
    	\else
    		\tcblower
    		\textcolor{theoreme!50!black}{\sffamily\textbf{Preuve.}}\\ #3
    	\fi
	}

